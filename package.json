{
  "name": "my-todo",
  "version": "1.0.0",
  "private": true,
  "description": "MyTODO - Cloudflare Pages + D1",
  "scripts": {
    "dev": "wrangler pages dev public --d1=DB",
    "deploy": "wrangler pages deploy public --project-name=my-todo",
    "db:create": "wrangler d1 create my-todo-db",
    "db:init:remote": "wrangler d1 execute my-todo-db --remote --file=./schema.sql",
    "db:init:local": "wrangler d1 execute my-todo-db --local --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
